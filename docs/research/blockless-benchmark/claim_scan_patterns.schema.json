{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blockless.dev/research/claim_scan_patterns.schema.json",
  "title": "Blockless Claim Scan Patterns",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "date", "patterns"],
  "properties": {
    "version": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pattern_id", "claim_id", "severity", "regex", "message"],
        "properties": {
          "pattern_id": { "type": "string" },
          "claim_id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["forbidden", "market_gated", "benchmark_gated", "review"]
          },
          "regex": { "type": "string" },
          "message": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
